# 이 파일을 복사해 .env.local 로 저장하고 값을 채우세요 (로컬 개발용).
# Vercel 배포 시에는 Vercel 대시보드 > Settings > Environment Variables 에 같은 이름으로 등록합니다.

# Supabase 대시보드 > Project Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# console.anthropic.com 에서 발급 (절대 GitHub에 올리지 마세요)
ANTHROPIC_API_KEY=
